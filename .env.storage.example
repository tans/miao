# Storage Configuration
# Provider: local | rustfs | s3 | oss | cos
STORAGE_PROVIDER=local

# RustFS Configuration (when STORAGE_PROVIDER=rustfs)
RUSTFS_ENDPOINT=https://rustfs.clawos.cc
RUSTFS_BUCKET=your-bucket
RUSTFS_ACCESS_KEY=your-access-key
RUSTFS_SECRET_KEY=your-secret-key
RUSTFS_REGION=us-east-1

# AWS S3 Configuration (when STORAGE_PROVIDER=s3)
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Aliyun OSS Configuration (when STORAGE_PROVIDER=oss)
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY=your-access-key
OSS_SECRET_KEY=your-secret-key
OSS_REGION=cn-hangzhou
OSS_CDN_HOST=

# Tencent COS Configuration (when STORAGE_PROVIDER=cos)
COS_APP_ID=your-app-id
COS_BUCKET=your-bucket
COS_REGION=ap-guangzhou
COS_SECRET_KEY=your-secret-key
COS_SECRET_ID=your-secret-id
COS_CDN_HOST=
