package handler

import (
	"net/http"
	"strconv"
	"time"

	"github.com/gin-gonic/gin"
	"github.com/tans/miao/internal/middleware"
	"github.com/tans/miao/internal/model"
)

// SubmissionResponse represents the standard API response
type SubmissionResponse struct {
	Code    int         `json:"code"`
	Message string      `json:"message"`
	Data    interface{} `json:"data"`
}

// CreateSubmission handles submission creation
// POST /api/v1/submissions
func CreateSubmission(c *gin.Context) {
	// Check creator role
	role, ok := middleware.GetRoleFromContext(c)
	if !ok || role != "creator" {
		c.JSON(http.StatusForbidden, SubmissionResponse{
			Code:    40302,
			Message: "仅创作者可提交投稿",
			Data:    nil,
		})
		return
	}

	creatorID, ok := middleware.GetUserIDFromContext(c)
	if !ok {
		c.JSON(http.StatusUnauthorized, SubmissionResponse{
			Code:    40101,
			Message: "未登录",
			Data:    nil,
		})
		return
	}

	creatorName, _ := middleware.GetUsernameFromContext(c)

	var req model.SubmissionCreate
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "参数错误: " + err.Error(),
			Data:    nil,
		})
		return
	}

	// Check if task exists
	task, err := GetTaskRepo().GetTaskByID(req.TaskID)
	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "获取任务失败",
			Data:    nil,
		})
		return
	}

	if task == nil {
		c.JSON(http.StatusNotFound, SubmissionResponse{
			Code:    40401,
			Message: "任务不存在",
			Data:    nil,
		})
		return
	}

	// Check if task is still accepting submissions
	if task.Status != model.TaskStatusOnline {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40002,
			Message: "任务已结束或不在上线状态",
			Data:    nil,
		})
		return
	}

	// Check deadline
	if time.Now().After(task.Deadline) {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40002,
			Message: "投稿已截止",
			Data:    nil,
		})
		return
	}

	// Check if creator already submitted to this task
	existingSub, err := GetSubmissionRepo().GetSubmissionByTaskAndCreator(req.TaskID, creatorID)
	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "检查投稿失败",
			Data:    nil,
		})
		return
	}

	if existingSub != nil && !task.AllowDuplicate {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40003,
			Message: "您已投稿过该任务",
			Data:    nil,
		})
		return
	}

	// Check max per user
	if task.MaxPerUser > 0 {
		subs, err := GetSubmissionRepo().ListSubmissionsByCreatorID(creatorID)
		if err != nil {
			c.JSON(http.StatusInternalServerError, SubmissionResponse{
				Code:    50001,
				Message: "检查投稿数失败",
				Data:    nil,
			})
			return
		}
		taskSubCount := 0
		for _, s := range subs {
			if s.TaskID == req.TaskID {
				taskSubCount++
			}
		}
		if taskSubCount >= task.MaxPerUser {
			c.JSON(http.StatusBadRequest, SubmissionResponse{
				Code:    40004,
				Message: "已达到该任务的最大投稿次数",
				Data:    nil,
			})
			return
		}
	}

	submission := &model.Submission{
		TaskID:      req.TaskID,
		CreatorID:   creatorID,
		CreatorName: creatorName,
		Content:     req.Content,
		Status:      model.SubmissionPending,
		AwardLevel:  model.AwardNone,
	}

	if err := GetSubmissionRepo().CreateSubmission(submission); err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "创建投稿失败: " + err.Error(),
			Data:    nil,
		})
		return
	}

	c.JSON(http.StatusOK, SubmissionResponse{
		Code:    0,
		Message: "提交投稿成功",
		Data: gin.H{
			"submission": formatSubmission(submission),
		},
	})
}

// GetSubmission handles getting a single submission by ID
// GET /api/v1/submissions/:id
func GetSubmission(c *gin.Context) {
	idStr := c.Param("id")
	id, err := strconv.ParseInt(idStr, 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "无效的投稿ID",
			Data:    nil,
		})
		return
	}

	submission, err := GetSubmissionRepo().GetSubmissionByID(id)
	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "获取投稿失败",
			Data:    nil,
		})
		return
	}

	if submission == nil {
		c.JSON(http.StatusNotFound, SubmissionResponse{
			Code:    40401,
			Message: "投稿不存在",
			Data:    nil,
		})
		return
	}

	c.JSON(http.StatusOK, SubmissionResponse{
		Code:    0,
		Message: "success",
		Data: gin.H{
			"submission": formatSubmission(submission),
		},
	})
}

// ListSubmissions handles listing submissions with optional filters
// GET /api/v1/submissions?task_id=xxx&creator_id=xxx&status=xxx
func ListSubmissions(c *gin.Context) {
	taskIDStr := c.Query("task_id")
	creatorIDStr := c.Query("creator_id")
	statusStr := c.Query("status")

	var submissions []*model.Submission
	var err error

	if taskIDStr != "" {
		taskID, parseErr := strconv.ParseInt(taskIDStr, 10, 64)
		if parseErr != nil {
			c.JSON(http.StatusBadRequest, SubmissionResponse{
				Code:    40001,
				Message: "无效的任务ID",
				Data:    nil,
			})
			return
		}
		submissions, err = GetSubmissionRepo().ListSubmissionsByTaskID(taskID)
	} else if creatorIDStr != "" {
		creatorID, parseErr := strconv.ParseInt(creatorIDStr, 10, 64)
		if parseErr != nil {
			c.JSON(http.StatusBadRequest, SubmissionResponse{
				Code:    40001,
				Message: "无效的创作者ID",
				Data:    nil,
			})
			return
		}
		submissions, err = GetSubmissionRepo().ListSubmissionsByCreatorID(creatorID)
	} else if statusStr != "" {
		status, parseErr := strconv.Atoi(statusStr)
		if parseErr != nil {
			c.JSON(http.StatusBadRequest, SubmissionResponse{
				Code:    40001,
				Message: "无效的状态值",
				Data:    nil,
			})
			return
		}
		submissions, err = GetSubmissionRepo().ListSubmissionsByStatus(model.SubmissionStatus(status))
	} else {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "请提供task_id、creator_id或status筛选条件",
			Data:    nil,
		})
		return
	}

	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "获取投稿列表失败",
			Data:    nil,
		})
		return
	}

	var formattedSubmissions []gin.H
	for _, sub := range submissions {
		formattedSubmissions = append(formattedSubmissions, formatSubmission(sub))
	}

	c.JSON(http.StatusOK, SubmissionResponse{
		Code:    0,
		Message: "success",
		Data: gin.H{
			"submissions": formattedSubmissions,
		},
	})
}

// ReviewSubmission handles reviewing a submission (business only)
// PUT /api/v1/submissions/:id/review
func ReviewSubmission(c *gin.Context) {
	// Check business role
	role, ok := middleware.GetRoleFromContext(c)
	if !ok || role != "business" {
		c.JSON(http.StatusForbidden, SubmissionResponse{
			Code:    40302,
			Message: "仅商家可审核投稿",
			Data:    nil,
		})
		return
	}

	businessID, ok := middleware.GetUserIDFromContext(c)
	if !ok {
		c.JSON(http.StatusUnauthorized, SubmissionResponse{
			Code:    40101,
			Message: "未登录",
			Data:    nil,
		})
		return
	}

	idStr := c.Param("id")
	id, err := strconv.ParseInt(idStr, 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "无效的投稿ID",
			Data:    nil,
		})
		return
	}

	// Get submission
	submission, err := GetSubmissionRepo().GetSubmissionByID(id)
	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "获取投稿失败",
			Data:    nil,
		})
		return
	}

	if submission == nil {
		c.JSON(http.StatusNotFound, SubmissionResponse{
			Code:    40401,
			Message: "投稿不存在",
			Data:    nil,
		})
		return
	}

	// Check if the business owns the task
	task, err := GetTaskRepo().GetTaskByID(submission.TaskID)
	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "获取任务失败",
			Data:    nil,
		})
		return
	}

	if task == nil || task.BusinessID != businessID {
		c.JSON(http.StatusForbidden, SubmissionResponse{
			Code:    40302,
			Message: "无权审核此投稿",
			Data:    nil,
		})
		return
	}

	var req model.SubmissionReview
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "参数错误: " + err.Error(),
			Data:    nil,
		})
		return
	}

	// Update submission status
	now := time.Now()
	submission.Status = req.Status
	submission.ReviewComment = req.ReviewComment
	submission.ReviewedAt = &now

	if err := GetSubmissionRepo().UpdateSubmission(submission); err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "更新投稿失败",
			Data:    nil,
		})
		return
	}

	// Update task reviewed_count
	if req.Status == model.SubmissionPassed {
		task.ReviewedCount++
		task.PassedCount++
		if err := GetTaskRepo().UpdateTask(task); err != nil {
			c.JSON(http.StatusInternalServerError, SubmissionResponse{
				Code:    50001,
				Message: "更新任务统计失败",
				Data:    nil,
			})
			return
		}
	} else if req.Status == model.SubmissionRejected {
		task.ReviewedCount++
		if err := GetTaskRepo().UpdateTask(task); err != nil {
			c.JSON(http.StatusInternalServerError, SubmissionResponse{
				Code:    50001,
				Message: "更新任务统计失败",
				Data:    nil,
			})
			return
		}
	}

	c.JSON(http.StatusOK, SubmissionResponse{
		Code:    0,
		Message: "审核成功",
		Data: gin.H{
			"submission": formatSubmission(submission),
		},
	})
}

// AwardSubmission handles awarding a submission (business only)
// PUT /api/v1/submissions/:id/award
func AwardSubmission(c *gin.Context) {
	// Check business role
	role, ok := middleware.GetRoleFromContext(c)
	if !ok || role != "business" {
		c.JSON(http.StatusForbidden, SubmissionResponse{
			Code:    40302,
			Message: "仅商家可评选获奖",
			Data:    nil,
		})
		return
	}

	businessID, ok := middleware.GetUserIDFromContext(c)
	if !ok {
		c.JSON(http.StatusUnauthorized, SubmissionResponse{
			Code:    40101,
			Message: "未登录",
			Data:    nil,
		})
		return
	}

	idStr := c.Param("id")
	id, err := strconv.ParseInt(idStr, 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "无效的投稿ID",
			Data:    nil,
		})
		return
	}

	// Get submission
	submission, err := GetSubmissionRepo().GetSubmissionByID(id)
	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "获取投稿失败",
			Data:    nil,
		})
		return
	}

	if submission == nil {
		c.JSON(http.StatusNotFound, SubmissionResponse{
			Code:    40401,
			Message: "投稿不存在",
			Data:    nil,
		})
		return
	}

	// Check if the business owns the task
	task, err := GetTaskRepo().GetTaskByID(submission.TaskID)
	if err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "获取任务失败",
			Data:    nil,
		})
		return
	}

	if task == nil || task.BusinessID != businessID {
		c.JSON(http.StatusForbidden, SubmissionResponse{
			Code:    40302,
			Message: "无权评选此投稿",
			Data:    nil,
		})
		return
	}

	// Check submission is already passed
	if submission.Status != model.SubmissionPassed {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40002,
			Message: "只有已通过的投稿才能评选获奖",
			Data:    nil,
		})
		return
	}

	var req model.SubmissionAward
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "参数错误: " + err.Error(),
			Data:    nil,
		})
		return
	}

	// Validate award level (1-4)
	if req.AwardLevel < model.Award1 || req.AwardLevel > model.AwardGood {
		c.JSON(http.StatusBadRequest, SubmissionResponse{
			Code:    40001,
			Message: "无效的获奖等级",
			Data:    nil,
		})
		return
	}

	// Calculate reward amount based on award level
	var rewardAmount float64
	switch req.AwardLevel {
	case model.Award1:
		rewardAmount = task.Award1Amount
	case model.Award2:
		rewardAmount = task.Award2Amount
	case model.Award3:
		rewardAmount = task.Award3Amount
	case model.AwardGood:
		rewardAmount = task.AwardGoodAmount
	}

	// Update submission
	submission.AwardLevel = req.AwardLevel
	submission.RewardAmount = rewardAmount
	now := time.Now()
	submission.ReviewedAt = &now

	if err := GetSubmissionRepo().UpdateSubmission(submission); err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "更新投稿失败",
			Data:    nil,
		})
		return
	}

	// Update task total_rewarded
	task.TotalRewarded += rewardAmount
	task.PassedCount++
	if err := GetTaskRepo().UpdateTask(task); err != nil {
		c.JSON(http.StatusInternalServerError, SubmissionResponse{
			Code:    50001,
			Message: "更新任务统计失败",
			Data:    nil,
		})
		return
	}

	c.JSON(http.StatusOK, SubmissionResponse{
		Code:    0,
		Message: "评选成功",
		Data: gin.H{
			"submission": formatSubmission(submission),
		},
	})
}

// formatSubmission converts a Submission model to a gin.H map
func formatSubmission(sub *model.Submission) gin.H {
	h := gin.H{
		"id":             sub.ID,
		"task_id":        sub.TaskID,
		"creator_id":     sub.CreatorID,
		"creator_name":   sub.CreatorName,
		"creator_avatar":  sub.CreatorAvatar,
		"content":        sub.Content,
		"status":         sub.Status,
		"award_level":    sub.AwardLevel,
		"score":          sub.Score,
		"review_comment": sub.ReviewComment,
		"reward_amount":  sub.RewardAmount,
		"is_used":        sub.IsUsed,
		"is_top":         sub.IsTop,
		"created_at":     sub.CreatedAt.Format(time.RFC3339),
	}

	if sub.ReviewedAt != nil {
		h["reviewed_at"] = sub.ReviewedAt.Format(time.RFC3339)
	}

	return h
}
