package main

import (
	"database/sql"
	"fmt"
	"log"

	_ "github.com/mattn/go-sqlite3"
	"golang.org/x/crypto/bcrypt"
)

func main() {
	// 连接数据库
	db, err := sql.Open("sqlite3", "data/miao.db")
	if err != nil {
		log.Fatal("Failed to connect to database:", err)
	}
	defer db.Close()

	// 新密码
	newPassword := "admin123"

	// 生成密码哈希
	hashedPassword, err := bcrypt.GenerateFromPassword([]byte(newPassword), bcrypt.DefaultCost)
	if err != nil {
		log.Fatal("Failed to hash password:", err)
	}

	// 更新管理员密码
	result, err := db.Exec("UPDATE users SET password_hash = ? WHERE username = ?", string(hashedPassword), "admin")
	if err != nil {
		log.Fatal("Failed to update password:", err)
	}

	rowsAffected, _ := result.RowsAffected()
	if rowsAffected == 0 {
		log.Fatal("Admin user not found")
	}

	fmt.Println("✅ 管理员密码已重置")
	fmt.Println("用户名: admin")
	fmt.Println("新密码:", newPassword)
	fmt.Println("手机号: 13800000000")
}
